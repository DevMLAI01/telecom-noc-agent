# =============================================================================
# .gitignore — Git Exclusion Rules
# =============================================================================

# Environment variables — NEVER commit API keys
.env

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environment directories
venv/
.venv/
env/
.env/

# ChromaDB local vector store (legacy — replaced by DynamoDB)
chroma_db/

# AWS SAM build artifacts
.aws-sam/
samconfig.toml

# Docker build artifacts
*.tar

# IDE and editor files
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# OS-generated files
.DS_Store
Thumbs.db

# Distribution / packaging
dist/
build/
*.egg-info/

# Test and coverage reports
.pytest_cache/
htmlcov/
.coverage
