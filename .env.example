# =============================================================================
# .env.example — Environment Variable Template
# =============================================================================
# Copy this file to .env and replace the placeholder values with your actual keys.
# NEVER commit your real .env file to version control.
#
# Usage:
#   cp .env.example .env
#   # Then edit .env with your real values
# =============================================================================

# OpenAI API Key — Required for GPT-4o (brain + critic) and text-embedding-3-small
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# AWS Configuration — Required for DynamoDB access
# For local development: run `aws configure` or set these vars directly.
# In Lambda: provided automatically by the execution role (do not set here).
AWS_REGION=us-east-1

# DynamoDB table names — created by scripts/seed_dynamodb.py
DYNAMODB_SOPS_TABLE=telecom-noc-sops
DYNAMODB_TELEMETRY_TABLE=telecom-noc-telemetry
